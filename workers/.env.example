# ── Redis ─────────────────────────────────────────────────────────────────────
# Local dev: redis://localhost:6379
# Production (AWS ElastiCache): rediss://<cluster>.cache.amazonaws.com:6379
REDIS_URL=redis://localhost:6379

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Storage public bucket for rendered social graphics
SUPABASE_SOCIAL_GRAPHICS_BUCKET=social-graphics

# ── Anthropic Claude (AI captions) ───────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Social platform credentials ───────────────────────────────────────────────
# Used for token refresh when access tokens expire
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=

# ── Application ───────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000

# ── Web Push / VAPID (copy from apps/web/.env.local) ─────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# ── Worker concurrency ────────────────────────────────────────────────────────
# Tune based on ECS task CPU/memory allocation
GRAPHIC_WORKER_CONCURRENCY=5
POST_WORKER_CONCURRENCY=10
PODIUM_WORKER_CONCURRENCY=2
